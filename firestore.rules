rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Deny everything by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'Mohammed.inezarene@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validations
    function isValidRider(data) {
      return ('id' in data) && (data.id is string) && (data.id.size() <= 128)
        && ('name' in data) && (data.name is string) && (data.name.size() <= 100)
        && ('type' in data) && (data.type is string) && (data.type == 'بارود' || data.type == 'خيال')
        && ('username' in data) && (data.username is string) && (data.username.size() <= 100)
        && ('status' in data) && (data.status is string) && (data.status == 'متاح' || data.status == 'في مهمة')
        && ('image' in data) && (data.image is string) && (data.image.size() <= 1000000)
        && (!('password' in data) || (data.password is string && data.password.size() <= 100));
    }

    function isValidBooking(data) {
      return ('id' in data) && (data.id is string) && (data.id.size() <= 128)
        && ('customerName' in data) && (data.customerName is string) && (data.customerName.size() <= 200)
        && ('phone' in data) && (data.phone is string) && (data.phone.size() <= 50)
        && ('date' in data) && (data.date is string) && (data.date.size() <= 50)
        && ('wilaya' in data) && (data.wilaya is string) && (data.wilaya.size() <= 100)
        && ('ridersCount' in data) && (data.ridersCount is int || data.ridersCount is float)
        && ('startPoint' in data) && (data.startPoint is string) && (data.startPoint.size() <= 500)
        && ('endPoint' in data) && (data.endPoint is string) && (data.endPoint.size() <= 500)
        && ('status' in data) && (data.status is string) && (data.status == 'قيد الانتظار' || data.status == 'مؤكد' || data.status == 'مكتمل' || data.status == 'ملغى')
        && ('assignedRiders' in data) && (data.assignedRiders is list)
        && ('createdAt' in data) && (data.createdAt is string) && (data.createdAt.size() <= 100)
        && (!('createdBy' in data) || (data.createdBy is string && data.createdBy.size() <= 200))
        && (!('quantityKg' in data) || (data.quantityKg is int || data.quantityKg is float))
        && (!('count' in data) || (data.count is int || data.count is float))
        && (!('riderPrice' in data) || (data.riderPrice is int || data.riderPrice is float));
    }

    function isValidSettings(data) {
      return ('ownerName' in data) && (data.ownerName is string) && (data.ownerName.size() <= 100)
        && ('appName' in data) && (data.appName is string) && (data.appName.size() <= 100)
        && ('ownerPicture' in data) && (data.ownerPicture is string) && (data.ownerPicture.size() <= 1000000);
    }

    function isValidNotification(data) {
      return ('id' in data) && (data.id is string) && (data.id.size() <= 128)
        && ('title' in data) && (data.title is string) && (data.title.size() <= 200)
        && ('message' in data) && (data.message is string) && (data.message.size() <= 1000)
        && ('type' in data) && (data.type is string) && (data.type == 'new_booking' || data.type == 'rider_assignment' || data.type == 'general')
        && ('isRead' in data) && (data.isRead is bool)
        && ('createdAt' in data) && (data.createdAt is string) && (data.createdAt.size() <= 100)
        && (!('targetUserId' in data) || (data.targetUserId is string && data.targetUserId.size() <= 128))
        && (!('bookingId' in data) || (data.bookingId is string && data.bookingId.size() <= 128));
    }

    // Collection matches
    match /riders/{riderId} {
      allow read: if true; 
      allow write: if true; // In the dev environment, allow write so that the app's local user interface functions properly to register/edit riders.
    }

    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read: if true;
      allow update, delete: if true; // Allowed in dev so status changes or updates are not blocked
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if true;
    }

    match /notifications/{notificationId} {
      allow create: if isValidNotification(request.resource.data);
      allow read, update, delete: if true;
    }
  }
}
